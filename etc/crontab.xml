<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="paymentretry_cronjob_ordercancel" instance="Rameera\Payment\Cron\Ordercancel" method="execute">
            <schedule>*/30 * * * *</schedule>
        </job>
        <job name="cancel_pending_payment_order" instance="Rameera\Payment\Cron\CancelPendingOrder" method="execute">
            <config_path>payment/payment_additional_configurations/pending_payment_cron_expression</config_path>
        </job>
    </group>
    <group id="adyen_payment">
        <job name="adyen_payment_cancel_expired_orders" instance="AdyenCancelOrders" method="execute">
            <schedule>0 0 30 2 *</schedule>
        </job>
    </group>
</config>
